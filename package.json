{
  "name": "graduation-project",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "format": "npx ultracite fix",
    "check:format": "npx ultracite check"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,json,md}": [
      "npx ultracite fix",
      "git add"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "turbo": "^2.6.1",
    "typescript": "5.9.2",
    "ultracite": "6.3.8"
  },
  "dependencies": {
    "better-auth": "^1.4.4"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
